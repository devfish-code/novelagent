{
  "name": "novelagent",
  "version": "0.1.0",
  "description": "AI驱动的长篇小说自动生成CLI工具",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "novelagent": "./dist/shells/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/shells/cli/index.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "npm run dev --prefix web",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "build": "tsc",
    "build:server": "tsc",
    "build:web": "npm run build --prefix web",
    "build:all": "npm run build:server && npm run build:web",
    "start": "NODE_ENV=production node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "novel",
    "writing",
    "cli",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fs-extra": "^11.2.0",
    "ws": "^8.20.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.17.10",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitest/coverage-v8": "^2.1.8",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "fast-check": "^4.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
